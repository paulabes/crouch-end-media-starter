---
import { siteConfig } from '../../site.config';

const PRIMARY = siteConfig.colors.primary;

const accent = {
  text: `text-[${PRIMARY}]`,
  border: `hover:border-[${PRIMARY}]`,
  bg: `bg-[${PRIMARY}]`,
  hoverBg: 'hover:bg-zinc-800',
  badgeBg: `bg-[${PRIMARY}]/20`,
  badgeBorder: `border-[${PRIMARY}]/40`,
};
---

<section id="services" class="py-24 px-6 md:px-12 bg-[#f4f4f5] overflow-hidden relative">
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-20 scroll-reveal opacity-0">
      <h2 class="font-grotesk text-3xl md:text-6xl mb-8 text-black leading-tight tracking-tight">
        What we do.
      </h2>
      <p class="font-grotesk text-zinc-900 text-xl font-bold leading-relaxed max-w-2xl mx-auto">
        Professional digital services tailored to your business needs.
      </p>
    </div>

    <div class:list={[
      "grid grid-cols-1 gap-8",
      siteConfig.services.length <= 3 ? "md:grid-cols-3" : "md:grid-cols-2 lg:grid-cols-3"
    ]}>
      {siteConfig.services.map((item, i) => {
        return (
          <a
            href={item.url}
            class={`p-8 bg-white border border-zinc-100 ${accent.border} ${accent.hoverBg} group scroll-reveal opacity-0 block relative overflow-hidden transition-colors`}
          >
            <div class={`absolute top-0 left-0 w-1 h-full ${accent.bg}`}></div>
            <div class={`inline-block px-3 py-1 ${accent.badgeBg} border ${accent.badgeBorder} ${accent.text} font-grotesk text-xs font-bold uppercase tracking-widest mb-4 group-hover:bg-white/20 group-hover:border-white/40 group-hover:text-white transition-colors`}>{item.tag}</div>
            <h3 class="font-grotesk text-2xl md:text-3xl mb-4 text-black group-hover:text-white leading-tight tracking-tight transition-colors">{item.title}</h3>
            <p class="text-zinc-700 group-hover:text-white font-grotesk font-medium leading-relaxed transition-colors">{item.description}</p>
          </a>
        );
      })}
    </div>
  </div>
</section>
