---
import { siteConfig } from '../../site.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title={`Terms of Service | ${siteConfig.name}`}
  description={`Terms of service for ${siteConfig.name}.`}
  noindex={true}
>
  <Navbar />

  <main id="main-content" class="bg-[#F5F4F0]">
    <section class="pt-48 pb-32 px-6 md:px-12">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-grotesk text-4xl md:text-5xl leading-tight tracking-tight text-black mb-12">
          Terms of Service
        </h1>

        <div class="prose prose-lg max-w-none font-grotesk text-zinc-700 space-y-8">
          <p class="text-lg font-bold">Last updated: {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>

          <h2 class="text-2xl text-black mt-12">Agreement</h2>
          <p>By accessing and using {siteConfig.siteUrl}, you agree to be bound by these Terms of Service.</p>

          <h2 class="text-2xl text-black mt-12">Services</h2>
          <p>{siteConfig.name} provides web design, development, and related digital services. All project work is subject to a separate agreement or proposal.</p>

          <h2 class="text-2xl text-black mt-12">Intellectual property</h2>
          <p>All content on this website, including text, graphics, and code, is the property of {siteConfig.legalName} unless otherwise stated. Client work is transferred upon full payment.</p>

          <h2 class="text-2xl text-black mt-12">Limitation of liability</h2>
          <p>{siteConfig.name} shall not be liable for any indirect, incidental, or consequential damages arising from the use of our services or this website.</p>

          <h2 class="text-2xl text-black mt-12">Changes</h2>
          <p>We reserve the right to update these terms at any time. Changes will be posted on this page.</p>

          <h2 class="text-2xl text-black mt-12">Contact</h2>
          <p>For questions about these terms, contact us at <a href={`mailto:${siteConfig.email}`} class="text-[#D4520A] hover:underline">{siteConfig.email}</a>.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
