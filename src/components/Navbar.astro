---
import { siteConfig } from '../../site.config';

const currentPath = Astro.url.pathname;
const PRIMARY = siteConfig.colors.primary;
const BG = siteConfig.colors.background;
---

<nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 px-6 xl:px-16 py-4 shadow-md bg-white/90 backdrop-blur-md nav-scrolled">
  <div class="w-full flex justify-between items-center">
    <a href="/" class="flex items-center gap-3 group cursor-pointer">
      <img
        id="nav-logo"
        src="/favicon.svg"
        alt=""
        class="h-8 w-8 transition-all duration-500 object-contain"
      />
      <span
        id="nav-logo-text"
        class="font-grotesk text-sm uppercase tracking-widest transition-colors duration-500 text-zinc-900"
      >{siteConfig.name}</span>
    </a>

    <div id="nav-links" class="hidden xl:flex gap-10 items-center font-grotesk text-sm font-bold uppercase tracking-widest transition-colors duration-500 text-zinc-900">
      {siteConfig.nav.links.map((link) => (
        <a
          href={link.href}
          class:list={['transition-colors', currentPath === link.href ? `text-[${PRIMARY}]` : `hover:text-[${PRIMARY}]`]}
        >{link.label}</a>
      ))}

      {/* Services Dropdown */}
      {siteConfig.services.length > 0 && (
        <div class="relative group">
          <a
            href="/services"
            class:list={['transition-colors flex items-center gap-1', currentPath.startsWith('/services') ? `text-[${PRIMARY}]` : `hover:text-[${PRIMARY}]`]}
          >
            Services
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <div class="absolute top-full -left-6 mt-4 w-80 bg-white border border-zinc-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 text-zinc-900">
            {siteConfig.services.map((service, i) => (
              <a
                href={service.url}
                class={`block px-6 py-3 text-xs text-zinc-900 hover:bg-[${BG}] hover:text-[${PRIMARY}] transition-colors ${i < siteConfig.services.length - 1 ? 'border-b border-zinc-100' : ''}`}
              >{service.tag}</a>
            ))}
          </div>
        </div>
      )}

      <a
        id="nav-contact-btn"
        href={siteConfig.nav.cta.href}
        class={`px-6 py-2 transition-all bg-[${PRIMARY}] text-white hover:bg-black hover:text-white`}
      >{siteConfig.nav.cta.label}</a>
    </div>

    <button id="mobile-menu-button" class="xl:hidden transition-colors duration-500 text-zinc-900" aria-label="Toggle menu" aria-expanded="false">
      <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
      <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu Panel -->
<div id="mobile-menu" class="xl:hidden fixed left-0 right-0 bottom-0 bg-white z-40 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto" style="top: 72px;">
    <div class="flex flex-col p-6 font-grotesk text-base font-bold uppercase tracking-widest text-zinc-900 h-full bg-white">
      {siteConfig.nav.links.map((link) => (
        <a href={link.href} class={`py-2 border-b border-zinc-200/50 hover:text-[${PRIMARY}] transition-colors`}>{link.label}</a>
      ))}

      {siteConfig.services.length > 0 && (
        <>
          <button id="mobile-services-toggle" class={`py-2 border-b border-zinc-200/50 hover:text-[${PRIMARY}] transition-colors flex justify-between items-center w-full text-left uppercase`}>
            Services
            <svg id="mobile-services-arrow" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id="mobile-services-submenu" class="hidden pl-4 text-base font-medium uppercase tracking-widest bg-zinc-50 px-4 py-2 mb-2 text-zinc-900">
            <a href="/services" class={`block py-2 hover:text-[${PRIMARY}] border-b border-zinc-200/50 font-bold`}>All Services</a>
            {siteConfig.services.map((service) => (
              <a href={service.url} class={`block py-2 hover:text-[${PRIMARY}] border-b border-zinc-200/50`}>{service.tag}</a>
            ))}
          </div>
        </>
      )}

      <a href={siteConfig.nav.cta.href} class={`mt-6 bg-black text-white text-center py-2 hover:bg-[${PRIMARY}] transition-colors`}>{siteConfig.nav.cta.label}</a>
    </div>
  </div>

<script>
  function initMobileMenu() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconOpen = document.getElementById('menu-icon-open');
    const menuIconClose = document.getElementById('menu-icon-close');
    const servicesToggle = document.getElementById('mobile-services-toggle');
    const servicesSubmenu = document.getElementById('mobile-services-submenu');
    const servicesArrow = document.getElementById('mobile-services-arrow');

    if (!mobileMenuButton || !mobileMenu || !menuIconOpen || !menuIconClose) return;

    if (servicesToggle && servicesSubmenu && servicesArrow) {
      servicesToggle.addEventListener('click', () => {
        servicesSubmenu.classList.toggle('hidden');
        servicesArrow.classList.toggle('rotate-180');
      });
    }

    let isOpen = false;
    const navbar = document.getElementById('navbar');

    const updateMenuPosition = () => {
      if (navbar && mobileMenu) {
        const navHeight = navbar.offsetHeight;
        mobileMenu.style.top = `${navHeight}px`;
      }
    };

    const toggleMenu = () => {
      isOpen = !isOpen;

      if (isOpen) {
        updateMenuPosition();
        mobileMenu.classList.remove('translate-x-full');
        mobileMenu.classList.add('translate-x-0');
        menuIconOpen.classList.add('hidden');
        menuIconClose.classList.remove('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.remove('translate-x-0');
        mobileMenu.classList.add('translate-x-full');
        menuIconOpen.classList.remove('hidden');
        menuIconClose.classList.add('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    };

    mobileMenuButton.addEventListener('click', toggleMenu);

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });
  }

  function init() {
    initMobileMenu();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
</script>
