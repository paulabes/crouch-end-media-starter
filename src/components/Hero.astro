---
import { siteConfig } from '../../site.config';

const PRIMARY = siteConfig.colors.primary;
const hero = siteConfig.hero;
---

<section id="hero" class="relative pt-40 pb-24 md:pt-48 md:pb-32 px-6 md:px-12 bg-zinc-900">
  <div class="max-w-4xl mx-auto text-center relative z-10">

    <div class="hero-stagger inline-block px-3 py-1 bg-white/10 border border-white/20 text-zinc-300 font-grotesk text-xs font-bold uppercase tracking-widest mb-8">
      {hero.badge}
    </div>

    <h1 class="hero-stagger font-grotesk text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight tracking-tight mb-6 text-white">
      {hero.typewriterLines.map((line) => (
        <span class="block">
          {line.white}{line.colored}{line.suffix}
        </span>
      ))}
    </h1>

    <p class="hero-stagger font-grotesk text-lg md:text-xl text-zinc-300 max-w-2xl mx-auto mb-10 leading-relaxed">
      {hero.subtitle}
    </p>

    <div class="hero-stagger flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={hero.primaryCta.href}
        class="bg-[#2563eb] text-white px-10 py-4 text-sm font-grotesk font-bold uppercase tracking-widest inline-flex items-center justify-center hover:bg-[#1d4ed8] transition-colors"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="border-2 border-white px-10 py-4 text-sm font-grotesk font-bold uppercase tracking-widest text-white hover:bg-white hover:text-zinc-900 hover:border-white transition-all flex items-center justify-center"
      >
        {hero.secondaryCta.label}
      </a>
    </div>

    {hero.stats.length > 0 && (
      <div class="hero-stagger mt-12 flex flex-wrap items-center justify-center gap-8">
        {hero.stats.map((stat, i) => (
          <>
            {i > 0 && <div class="hidden sm:block w-px h-8 bg-white/30"></div>}
            <div class="text-center">
              <div class="text-2xl md:text-3xl font-bold text-white">{stat.value}</div>
              <div class="text-xs font-bold uppercase tracking-widest text-zinc-400 mt-1">{stat.label}</div>
            </div>
          </>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  @keyframes hero-enter {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-stagger {
    opacity: 0;
    animation: hero-enter 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }
  .hero-stagger:nth-child(1) { animation-delay: 0.1s; }
  .hero-stagger:nth-child(2) { animation-delay: 0.25s; }
  .hero-stagger:nth-child(3) { animation-delay: 0.4s; }
  .hero-stagger:nth-child(4) { animation-delay: 0.55s; }
  .hero-stagger:nth-child(5) { animation-delay: 0.7s; }
</style>
