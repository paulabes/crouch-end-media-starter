---
import { siteConfig } from '../../site.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const PRIMARY = siteConfig.colors.primary;
---

<BaseLayout
  title={`Page Not Found | ${siteConfig.name}`}
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <Navbar />

  <main id="main-content" class="bg-[#F5F4F0]">
    <section class="min-h-screen flex items-center justify-center px-6 md:px-12 relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-5 pointer-events-none select-none font-grotesk text-[30rem] leading-none text-zinc-400">
        404
      </div>
      <div class="max-w-2xl text-center relative z-10">
        <div class={`inline-block px-3 py-1 bg-[${PRIMARY}]/20 border border-[${PRIMARY}]/40 text-[${PRIMARY}] font-grotesk text-xs font-bold uppercase tracking-widest mb-8`}>
          Page Not Found
        </div>
        <h1 class="font-grotesk text-5xl md:text-7xl leading-tight tracking-tight text-black mb-8">
          Oops. <span class={`text-[${PRIMARY}]`}>Nothing here.</span>
        </h1>
        <p class="font-grotesk text-xl text-zinc-600 leading-relaxed font-bold mb-12">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <a
          href="/"
          class={`inline-flex items-center gap-4 bg-zinc-900 text-white px-10 py-4 text-sm font-grotesk font-bold uppercase tracking-widest hover:bg-[${PRIMARY}] transition-colors`}
        >
          Back to Home
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
