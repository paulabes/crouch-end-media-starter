---
import { siteConfig } from '../../site.config';

const currentYear = new Date().getFullYear();
const PRIMARY = siteConfig.colors.primary;
const footer = siteConfig.footer;
const social = siteConfig.social;
---

<footer class="bg-black text-[#F5F4F0] py-20 px-6 md:px-12 border-t border-zinc-900 relative overflow-hidden">
  <!-- Decorative Background Text -->
  <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/3 opacity-5 pointer-events-none select-none overflow-hidden font-grotesk text-[40rem] leading-none -rotate-90 text-white">
    {footer.watermark}
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <div class="col-span-1 lg:col-span-2">
        <h2 class="font-grotesk text-3xl md:text-6xl mb-8 leading-tight tracking-tight">
          {footer.heading} <span class={`text-[${PRIMARY}]`}>{footer.headingAccent}</span>
        </h2>
        <p class="font-grotesk text-zinc-300 text-lg max-w-md mb-8 font-medium leading-relaxed">
          {footer.description}
        </p>
        <a href={footer.ctaLink} class={`inline-block bg-[${PRIMARY}] text-white px-8 py-4 font-grotesk font-bold uppercase tracking-widest text-xs hover:bg-white hover:text-black transition-colors`}>
          {footer.ctaLabel}
        </a>
      </div>

      <div>
        <h4 class={`font-grotesk font-bold tracking-widest text-[${PRIMARY}] text-xs mb-8`}>Services</h4>
        <ul class="space-y-4 font-grotesk uppercase text-xs tracking-widest">
          {siteConfig.services.map((service) => (
            <li><a href={service.url} class={`text-zinc-200 hover:text-[${PRIMARY}] transition-colors`}>{service.tag}</a></li>
          ))}
        </ul>
      </div>

      <div class="space-y-12">
        <div>
          <h4 class={`font-grotesk font-bold tracking-widest text-[${PRIMARY}] text-xs mb-6`}>Address</h4>
          <address class="not-italic font-grotesk text-xs uppercase tracking-widest space-y-1 text-zinc-400">
            <p>{siteConfig.legalName}</p>
            <p>{siteConfig.address.street}</p>
            <p>{siteConfig.address.locality}</p>
            <p>{siteConfig.address.postcode}</p>
          </address>
        </div>
        <div>
          <h4 class={`font-grotesk font-bold tracking-widest text-[${PRIMARY}] text-xs mb-6`}>Phone</h4>
          <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class={`font-grotesk text-xs uppercase tracking-widest text-white hover:text-[${PRIMARY}] transition-colors`}>
            {siteConfig.phone}
          </a>
        </div>
        {(social.twitter || social.youtube || social.linkedin || social.instagram) && (
          <div>
            <h4 class={`font-grotesk font-bold tracking-widest text-[${PRIMARY}] text-xs mb-6`}>Follow us</h4>
            <div class="flex gap-3">
              {social.twitter && (
                <a href={social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Follow us on X (Twitter)" class={`text-white hover:text-[${PRIMARY}] transition-colors`}>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              )}
              {social.youtube && (
                <a href={social.youtube} target="_blank" rel="noopener noreferrer" aria-label="Subscribe on YouTube" class={`text-white hover:text-[${PRIMARY}] transition-colors`}>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              )}
              {social.linkedin && (
                <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Connect on LinkedIn" class={`text-white hover:text-[${PRIMARY}] transition-colors`}>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
              {social.instagram && (
                <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Follow on Instagram" class={`text-white hover:text-[${PRIMARY}] transition-colors`}>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row justify-between items-center gap-6 px-6 md:px-12 py-6 font-grotesk text-[10px] uppercase tracking-widest text-zinc-400">
    <p>&copy; {currentYear} {siteConfig.legalName}{siteConfig.registrationNumber ? `. Company Registration No. ${siteConfig.registrationNumber}.` : ''}</p>
    <div class="flex gap-10">
      <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
    </div>
  </div>
</footer>
