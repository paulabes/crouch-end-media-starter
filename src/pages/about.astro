---
import { siteConfig } from '../../site.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';

const PRIMARY = siteConfig.colors.primary;
---

<BaseLayout
  title={`About Us | ${siteConfig.name}`}
  description={`Learn about ${siteConfig.name} — ${siteConfig.description}`}
>
  <Navbar />

  <main id="main-content" class="bg-[#F5F4F0]">
    <div id="scroll-progress" class={`fixed top-0 left-0 h-1 bg-[${PRIMARY}] z-[60] transition-all duration-100 ease-out`} style="width: 0%" />

    <!-- Hero -->
    <section class="pt-48 pb-20 px-6 md:px-12 bg-[#F5F4F0] relative overflow-hidden">
      <div class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/4 opacity-5 pointer-events-none select-none font-grotesk text-[18rem] md:text-[25rem] leading-none text-zinc-400">
        About
      </div>
      <div class="max-w-4xl mx-auto text-center scroll-reveal opacity-0 relative z-10">
        <div class={`inline-block px-3 py-1 bg-[${PRIMARY}]/20 border border-[${PRIMARY}]/40 text-[${PRIMARY}] font-grotesk text-xs font-bold uppercase tracking-widest mb-8`}>
          About
        </div>
        <h1 class="font-grotesk text-5xl md:text-[5.5rem] leading-tight tracking-tight text-black mb-10">
          We build websites that <span class={`text-[${PRIMARY}]`}>work.</span>
        </h1>
        <p class="font-grotesk text-xl md:text-2xl text-zinc-600 leading-relaxed font-bold max-w-3xl mx-auto">
          A small, experienced team delivering fast, beautiful websites. No account managers, no middlemen — just direct access to the people who build your project.
        </p>
      </div>
    </section>

    <!-- Values -->
    <section class="py-24 bg-[#F5F4F0] border-b border-zinc-100">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="text-center mb-16 scroll-reveal opacity-0">
          <h2 class="text-3xl md:text-5xl leading-[1.1] tracking-tight mb-8 font-grotesk text-black">How we <span class={`text-[${PRIMARY}]`}>work.</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-200 border border-zinc-200 shadow-sm">
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#F5F4F0] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-[${PRIMARY}] mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-[${PRIMARY}] rounded-full`}></span> 01
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-[${PRIMARY}] transition-colors`}>No middlemen.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              You talk directly to the people building your site. No account managers means decisions happen fast and nothing gets lost.
            </p>
          </div>
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#F5F4F0] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-[${PRIMARY}] mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-[${PRIMARY}] rounded-full`}></span> 02
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-[${PRIMARY}] transition-colors`}>Fast & lightweight.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              We write clean, semantic code that loads instantly and ranks well. No bloated themes or unnecessary dependencies.
            </p>
          </div>
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#F5F4F0] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-[${PRIMARY}] mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-[${PRIMARY}] rounded-full`}></span> 03
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-[${PRIMARY}] transition-colors`}>Results focused.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              Every decision is driven by what will deliver the best outcome for your business. We measure success by your success.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Placeholder -->
    <section class="py-24 px-6 md:px-12 bg-white border-t border-zinc-100 relative overflow-hidden">
      <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/3 opacity-5 pointer-events-none select-none font-grotesk text-[20rem] leading-none -rotate-90 text-zinc-400">
        Team
      </div>
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-16 text-center scroll-reveal opacity-0">
          <h2 class="text-3xl md:text-5xl leading-[1.1] tracking-tight mb-8 font-grotesk text-black">
            Meet the <span class={`text-[${PRIMARY}]`}>team.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {['Founder & Lead', 'Designer', 'Developer'].map((role, i) => (
            <div class="group scroll-reveal opacity-0">
              <div class="aspect-[3/4] bg-zinc-100 border border-zinc-200 mb-6 overflow-hidden relative flex items-center justify-center">
                <span class="font-grotesk text-zinc-300 text-6xl font-bold">{['A', 'B', 'C'][i]}</span>
                <div class={`absolute inset-0 bg-[${PRIMARY}]/0 group-hover:bg-[${PRIMARY}]/10 transition-colors duration-500`}></div>
              </div>
              <div class={`font-mono text-[10px] text-[${PRIMARY}] mb-2`}>{role}</div>
              <h3 class={`font-grotesk text-2xl text-black leading-tight tracking-tight mb-3 group-hover:text-[${PRIMARY}] transition-colors`}>
                {['Team Member', 'Team Member', 'Team Member'][i]}
              </h3>
              <p class="font-grotesk text-base text-zinc-600 leading-relaxed">
                A brief bio about this team member and their expertise. Replace with real content.
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CallToAction
      accentColor="orange"
      heading="Want to work"
      headingAccent="with us?"
      description="We'd love to hear about your project. Get in touch and we'll respond within 24 hours."
      buttonText="Get in Touch"
    />
  </main>

  <Footer />

  <script>
    const updateScrollProgress = () => {
      const progressBar = document.getElementById('scroll-progress');
      if (!progressBar) return;
      const totalScroll = document.documentElement.scrollHeight - window.innerHeight;
      const currentScroll = window.pageYOffset;
      const progress = (currentScroll / totalScroll) * 100;
      progressBar.style.width = `${progress}%`;
    };
    window.addEventListener('scroll', updateScrollProgress);
    document.addEventListener('astro:page-load', () => { window.addEventListener('scroll', updateScrollProgress); });
  </script>
</BaseLayout>
