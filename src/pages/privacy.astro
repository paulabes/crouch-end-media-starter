---
import { siteConfig } from '../../site.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title={`Privacy Policy | ${siteConfig.name}`}
  description={`Privacy policy for ${siteConfig.name}.`}
  noindex={true}
>
  <Navbar />

  <main id="main-content" class="bg-[#f4f4f5]">
    <section class="pt-48 pb-32 px-6 md:px-12">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-grotesk text-4xl md:text-5xl leading-tight tracking-tight text-black mb-12">
          Privacy Policy
        </h1>

        <div class="prose prose-lg max-w-none font-grotesk text-zinc-700 space-y-8">
          <p class="text-lg font-bold">Last updated: {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>

          <h2 class="text-2xl text-black mt-12">Who we are</h2>
          <p>{siteConfig.name} ({siteConfig.legalName}). Our website address is: {siteConfig.siteUrl}.</p>

          <h2 class="text-2xl text-black mt-12">What data we collect</h2>
          <p>When you use our contact form, we collect your name, email address, phone number (optional), and project brief. This information is used solely to respond to your enquiry.</p>

          <h2 class="text-2xl text-black mt-12">Cookies</h2>
          <p>We use essential cookies for site functionality. We use Vercel Analytics for anonymous performance monitoring — no personal data is collected.</p>

          <h2 class="text-2xl text-black mt-12">How we use your data</h2>
          <p>Your data is used only to respond to enquiries and provide our services. We do not sell, rent, or share your personal information with third parties.</p>

          <h2 class="text-2xl text-black mt-12">Data retention</h2>
          <p>Contact form submissions are retained for the duration of the business relationship. You may request deletion at any time by emailing {siteConfig.email}.</p>

          <h2 class="text-2xl text-black mt-12">Your rights</h2>
          <p>You have the right to access, correct, or delete your personal data. Contact us at {siteConfig.email} to exercise these rights.</p>

          <h2 class="text-2xl text-black mt-12">Contact</h2>
          <p>For privacy-related enquiries, contact us at <a href={`mailto:${siteConfig.email}`} class="text-[#27272a] hover:underline">{siteConfig.email}</a>.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
