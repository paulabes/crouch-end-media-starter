---
import { siteConfig } from '../../site.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';

const PRIMARY = siteConfig.colors.primary;
---

<BaseLayout
  title={`About Us | ${siteConfig.name}`}
  description={`Learn about ${siteConfig.name} — ${siteConfig.description}`}
>
  <Navbar />

  <main id="main-content" class="bg-[#f4f4f5]">
    <div id="scroll-progress" class={`fixed top-0 left-0 h-1 bg-[${PRIMARY}] z-[60] transition-all duration-100 ease-out`} style="width: 0%" />

    <!-- Hero -->
    <section class="pt-48 pb-20 px-6 md:px-12 bg-zinc-900 relative overflow-hidden">
      <div class="max-w-4xl mx-auto text-center scroll-reveal opacity-0 relative z-10">
        <div class={`inline-block px-3 py-1 bg-white/10 border border-white/20 text-zinc-300 font-grotesk text-xs font-bold uppercase tracking-widest mb-8`}>
          About
        </div>
        <h1 class="font-grotesk text-5xl md:text-[5.5rem] leading-tight tracking-tight text-white mb-10">
          Built on trust and hard work.
        </h1>
        <p class="font-grotesk text-xl md:text-2xl text-zinc-300 leading-relaxed font-bold max-w-3xl mx-auto">
          We're a small, dedicated team that believes in doing things properly. Our customers come back because we deliver on our promises and treat every job like it matters — because it does.
        </p>
      </div>
    </section>

    <!-- Values -->
    <section class="py-24 bg-[#f4f4f5] border-b border-zinc-100">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="text-center mb-16 scroll-reveal opacity-0">
          <h2 class="text-3xl md:text-5xl leading-[1.1] tracking-tight mb-8 font-grotesk text-black">How we work.</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-200 border border-zinc-200 shadow-sm">
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#f4f4f5] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-zinc-400 mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-zinc-400 rounded-full`}></span> 01
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-zinc-500 transition-colors`}>Personal service.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              You deal directly with the people doing the work. No call centres, no being passed around — just straightforward, honest communication.
            </p>
          </div>
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#f4f4f5] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-zinc-400 mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-zinc-400 rounded-full`}></span> 02
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-zinc-500 transition-colors`}>Fair and transparent.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              No hidden fees, no surprises. We give you a clear quote upfront and stick to it. You'll always know exactly what you're paying for.
            </p>
          </div>
          <div class="bg-white p-12 scroll-reveal opacity-0 hover:bg-[#f4f4f5] transition-colors duration-300 group cursor-default">
            <div class={`font-mono text-[10px] text-zinc-400 mb-6 flex items-center gap-2`}>
              <span class={`w-1 h-1 bg-zinc-400 rounded-full`}></span> 03
            </div>
            <h3 class={`font-grotesk text-xl md:text-2xl mb-6 text-black leading-tight group-hover:text-zinc-500 transition-colors`}>Quality guaranteed.</h3>
            <p class="font-grotesk text-base text-zinc-600 leading-relaxed font-medium">
              We take pride in every job, big or small. If you're not completely happy with our work, we'll make it right — that's our promise.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Placeholder -->
    <section class="py-24 px-6 md:px-12 bg-white border-t border-zinc-100 relative overflow-hidden">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-16 text-center scroll-reveal opacity-0">
          <h2 class="text-3xl md:text-5xl leading-[1.1] tracking-tight mb-8 font-grotesk text-black">
            Meet the team.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          {['Founder', 'Operations', 'Customer Support'].map((role, i) => (
            <div class="group scroll-reveal opacity-0">
              <div class="aspect-[3/4] bg-zinc-100 border border-zinc-200 mb-6 overflow-hidden relative flex items-center justify-center">
                <span class="font-grotesk text-zinc-300 text-6xl font-bold">{['JD', 'AD', 'SD'][i]}</span>
                <div class={`absolute inset-0 bg-zinc-900/0 group-hover:bg-zinc-900/10 transition-colors duration-500`}></div>
              </div>
              <div class={`font-mono text-[10px] text-zinc-400 mb-2`}>{role}</div>
              <h3 class={`font-grotesk text-2xl text-black leading-tight tracking-tight mb-3 group-hover:text-zinc-500 transition-colors`}>
                {['Jane Doe', 'Alex Doe', 'Sam Doe'][i]}
              </h3>
              <p class="font-grotesk text-base text-zinc-600 leading-relaxed">
                {[
                  'Founded the business over a decade ago with a simple goal: provide outstanding service that people can rely on. Still hands-on every day.',
                  'Keeps everything running behind the scenes so our customers get a seamless experience from start to finish.',
                  'The first person you\'ll speak to and the one who makes sure every customer feels looked after.',
                ][i]}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CallToAction
      accentColor="purple"
      heading="Want to work"
      headingAccent="with us?"
      description="We'd love to hear from you. Get in touch for a friendly chat about how we can help — no pressure, no hard sell."
      buttonText="Get in Touch"
    />
  </main>

  <Footer />

  <script>
    const updateScrollProgress = () => {
      const progressBar = document.getElementById('scroll-progress');
      if (!progressBar) return;
      const totalScroll = document.documentElement.scrollHeight - window.innerHeight;
      const currentScroll = window.pageYOffset;
      const progress = (currentScroll / totalScroll) * 100;
      progressBar.style.width = `${progress}%`;
    };
    window.addEventListener('scroll', updateScrollProgress);
    document.addEventListener('astro:page-load', () => { window.addEventListener('scroll', updateScrollProgress); });
  </script>
</BaseLayout>
