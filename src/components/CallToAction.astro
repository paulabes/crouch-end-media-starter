---
interface Props {
  heading: string;
  headingAccent?: string;
  description: string;
  buttonText?: string;
  buttonLink?: string;
  variant?: 'orange' | 'light';
  accentColor?: 'orange' | 'purple' | 'green' | 'amber' | 'blue' | 'cyan' | 'pink';
}

const {
  heading,
  headingAccent,
  description,
  buttonText = "Get in Touch",
  buttonLink = "/contact",
  variant = "light",
  accentColor = "orange"
} = Astro.props;

const isOrange = variant === 'orange';

const colorClasses = {
  orange: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  purple: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  green: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  amber: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  blue: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  cyan: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
  pink: { bg: 'bg-[#27272a]/10', text: 'text-[#27272a]', button: 'bg-[#27272a]' },
};

const colors = colorClasses[accentColor];
---

<section class:list={[
  "py-24 px-6 md:px-12 relative overflow-hidden",
  isOrange ? "bg-[#27272a] text-white" : `${colors.bg} text-black`
]}>
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h2 class:list={[
      "font-grotesk text-3xl md:text-6xl leading-tight tracking-tight mb-8",
      isOrange ? "text-white" : "text-black"
    ]}>
      {heading} <span class={`${isOrange ? "text-black" : colors.text}`}>{headingAccent}</span>
    </h2>
    <p class:list={[
      "font-grotesk text-xl leading-relaxed font-bold max-w-2xl mx-auto mb-12",
      isOrange ? "text-white/90" : "text-zinc-700"
    ]}>
      {description}
    </p>
    <a
      href={buttonLink}
      class={`group inline-flex items-center gap-4 px-10 py-4 font-grotesk font-bold uppercase tracking-widest text-sm transition-all duration-300 ${isOrange ? "bg-[#2563eb] text-white hover:bg-[#1d4ed8]" : "bg-[#2563eb] text-white hover:bg-[#1d4ed8]"}`}
    >
      {buttonText}
      <svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>
